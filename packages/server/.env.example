# Guardian Server Configuration
# Copy this file to .env and configure the values

# ==========================================
# Server Configuration
# ==========================================

# Port the server will listen on (default: 8080)
PORT=8080

# ==========================================
# Security (REQUIRED)
# ==========================================

# JWT Secret Key - REQUIRED for authentication
# Generate a secure random string for production:
#   Linux/Mac: openssl rand -base64 32
#   PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 256 }) -as [byte[]])
#   Or use: https://generate-secret.vercel.app/64
JWT_SECRET=replace_with_a_secure_random_string

# ==========================================
# Cloudflare Tunnel (Optional)
# ==========================================
# Token from Cloudflare Zero Trust Dashboard
# Required if using the 'cloudflared' service for HTTPS access
# Get this from: Networks > Tunnels > [Your Tunnel] > Configure
TUNNEL_TOKEN=

# ==========================================
# Docker Deployment Notes
# ==========================================
# 1. Copy this file to .env and set a real JWT_SECRET (do NOT paste compose ${...} syntax)
# 2. Create the data folder on the host before first start:
#      CasaOS:  mkdir -p /DATA/AppData/guardian-server/data
#      Other:   edit the bind mount in docker-compose.yml to any path you prefer
# 3. Start:
#      docker compose --env-file .env up -d
#      Optional Cloudflare Tunnel: docker compose --profile tunnel up -d
# 4. CasaOS: App Store → Custom Install → Docker Compose → paste docker-compose.yml,
#    then fill JWT_SECRET in the Environment Variables section.
# 5. Access: http://<host>:8080
# 6. The first user to register becomes the admin — set ADMIN_INVITE_CODE to secure this.

# ==========================================
# Admin Setup (Recommended)
# ==========================================
# Code required to create the first admin account
# If not set, the first user can register without a code (Insecure for public servers)
ADMIN_INVITE_CODE=
